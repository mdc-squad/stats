# Legacy Google Apps Script API (used by default for all tabs).
# NEXT_PUBLIC_MDC_API_BASE=https://api.hungryfishteam.org/gas/mdc

# --- New .NET REST API integration (feature/test-api) ---
#
# When true, the Календарь/Лайнап/Игроки/Игры tabs source their data from the new .NET REST API
# (via the app/api/rest/[...path] proxy route) instead of the legacy Google Apps Script API.
# Every other tab (leaderboards, roles, records, group) always uses the legacy API.
NEXT_PUBLIC_USE_REST_API=true

# Server-only: base URL of the mdc-squad-backend .NET API that app/api/rest/[...path]/route.ts
# proxies to. Never exposed to the browser. Defaults to http://localhost:5299/api/v1 if unset.
MDC_REST_API_BASE=http://localhost:5299/api/v1
